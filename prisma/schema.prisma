generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
  VIEWER
}

enum SourceType {
  BAZAR
  IGREJA
  PESSOA_FISICA
  BRECHO
  OUTRO
}

enum PieceCondition {
  NOVA
  EXCELENTE
  BOA
  REGULAR
}

enum PieceStatus {
  RECEBIDA
  HIGIENIZACAO
  AJUSTE
  ESTOQUE
  CONSIGNADA
  VENDIDA
  RETORNADA
  USO_PESSOAL
  DOADA
}

enum Gender {
  MASCULINO
  FEMININO
  UNISSEX
  INFANTIL
}

enum ConsignmentStatus {
  ACTIVE
  FINISHED
  RETURNED
}

model Company {
  id           String         @id @default(cuid())
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  users        User[]
  lots         Lot[]
  categories   Category[]
  brands       Brand[]
  sizes        Size[]
  colors       Color[]
  pieces       Piece[]
  stores       Store[]
  consignments Consignment[]
  revenues     Revenue[]
  expenses     Expense[]
  calendarEvents CalendarEvent[]
}

model User {
  id            String         @id @default(cuid())
  companyId     String
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          Role           @default(EMPLOYEE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]
  pieceHistory  PieceHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lot {
  id           String     @id @default(cuid())
  companyId    String
  code         String
  purchaseDate DateTime
  sourceName   String
  sourceType   SourceType
  totalCost    Float
  quantity     Int
  notes        String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pieces       Piece[]
}

model Category {
  id        String  @id @default(cuid())
  companyId String
  name      String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pieces    Piece[]
}

model Brand {
  id        String  @id @default(cuid())
  companyId String
  name      String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pieces    Piece[]
}

model Size {
  id        String  @id @default(cuid())
  companyId String
  name      String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pieces    Piece[]
}

model Color {
  id        String  @id @default(cuid())
  companyId String
  name      String
  hexCode   String?
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pieces    Piece[]
}

model Piece {
  id                 String                 @id @default(cuid())
  companyId          String
  lotId              String
  code               String
  qrCode             String                 @unique
  name               String
  categoryId         String
  brandId            String
  colorId            String
  sizeId             String
  condition          PieceCondition?
  tags               String[]               @default([])
  observations       String?
  gender             Gender
  status             PieceStatus            @default(RECEBIDA)
  purchasePrice      Float
  estimatedSalePrice Float
  notes              String?                @db.Text
  room               String?
  rack               String?
  box                String?
  drawer             String?
  storeId            String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lot                Lot                    @relation(fields: [lotId], references: [id], onDelete: Cascade)
  category           Category               @relation(fields: [categoryId], references: [id])
  brand              Brand                  @relation(fields: [brandId], references: [id])
  size               Size                   @relation(fields: [sizeId], references: [id])
  color              Color                  @relation(fields: [colorId], references: [id])
  store              Store?                 @relation(fields: [storeId], references: [id])
  images             PieceImage[]
  history            PieceHistory[]
  consignmentItems   ConsignmentItem[]
  apportionments     ExpenseApportionment[]
}

model PieceImage {
  id       String @id @default(cuid())
  pieceId  String
  imageUrl String
  order    Int    @default(0)
  piece    Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)
}

model PieceHistory {
  id             String       @id @default(cuid())
  pieceId        String
  userId         String
  previousStatus PieceStatus?
  newStatus      PieceStatus
  description    String?      @db.Text
  createdAt      DateTime     @default(now())
  piece          Piece        @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
}

model Store {
  id                   String        @id @default(cuid())
  companyId            String
  name                 String
  phone                String?
  email                String?
  address              String?
  commissionPercentage Float
  notes                String?       @db.Text
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  company              Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consignments         Consignment[]
  pieces               Piece[]
}

model Consignment {
  id                 String            @id @default(cuid())
  companyId          String
  storeId            String
  startDate          DateTime
  expectedReturnDate DateTime?
  status             ConsignmentStatus @default(ACTIVE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store              Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items              ConsignmentItem[]
}

model ConsignmentItem {
  consignmentId   String
  pieceId         String
  status          String  @default("ACCEPTED")
  rejectionReason String?
  listedPrice     Float
  salePrice       Float?
  commissionValue Float?
  netValue        Float?
  consignment     Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  piece           Piece       @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@id([consignmentId, pieceId])
}

model Revenue {
  id          String      @id @default(cuid())
  companyId   String
  amount      Float
  type        String
  description String?     @db.Text
  date        DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String                 @id @default(cuid())
  companyId     String
  amount        Float
  category      String
  description   String?                @db.Text
  date          DateTime
  isApportioned Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  apportionments ExpenseApportionment[]
}

model ExpenseApportionment {
  id        String  @id @default(cuid())
  expenseId String
  pieceId   String
  amount    Float
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  piece     Piece   @relation(fields: [pieceId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  description String?  @db.Text
  location    String?
  startDate   DateTime
  isAllDay    Boolean  @default(false)
  type        String   @default("TAREFA") // TAREFA, A_FAZER, EVENTO, BAZAR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}