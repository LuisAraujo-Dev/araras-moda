generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Perfis de Acesso do SaaS
enum Role {
  OWNER
  MANAGER
  EMPLOYEE
  VIEWER
}

// Tipos de Origem de Compra
enum SourceType {
  BAZAR
  IGREJA
  PESSOA_FISICA
  BRECHO
  OUTRO
}

// Tabela Raiz (Multi-Tenant)
model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  lots      Lot[]
}

model User {
  id            String    @id @default(cuid())
  companyId     String
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EMPLOYEE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lot {
  id           String     @id @default(cuid())
  companyId    String
  code         String     // Código visual (ex: Lote 001)
  purchaseDate DateTime
  sourceName   String     // Nome do local/pessoa
  sourceType   SourceType
  totalCost    Float      // Custo total em Reais (R$)
  quantity     Int        // Quantidade de peças adquiridas
  notes        String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
}